
import polars as pl


def reorder_columns(df: pl.DataFrame, column_order: list[str]) -> pl.DataFrame:
    existing = [col for col in column_order if col in df.columns]
    remaining = [col for col in df.columns if col not in existing]
    return df.select(existing + remaining)


def remove_columns(df: pl.DataFrame, columns_to_remove: list[str]) -> pl.DataFrame:
    keep_columns = [col for col in df.columns if col not in columns_to_remove]
    return df.select(keep_columns)


def rename_column(df: pl.DataFrame, old_name: str, new_name: str) -> pl.DataFrame:
    if old_name not in df.columns:
        return df

    return df.rename({old_name: new_name})
