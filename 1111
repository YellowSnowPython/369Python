import tkinter as tk
from tkinter import ttk
from tkinter import filedialog
from tkinter import messagebox

from config import (
    DEFAULT_DATA_FOLDER,
    ensure_app_folders,
)

from core.audit import (
    log_action,
    read_audit_log,
)

from core.file_registry import (
    list_csv_files,
    profile_many_files,
)


class DataWorkbenchApp:

    def __init__(self):

        ensure_app_folders()

        self.root = tk.Tk()

        self.root.title(
            "Trade Data Workbench"
        )

        self.root.geometry("1500x850")

        self.data_folder = DEFAULT_DATA_FOLDER

        self.csv_files = []

        self.profiles = []

        self.build_layout()

    def run(self):

        self.root.mainloop()

    def build_layout(self):

        self.build_top_bar()

        self.build_left_menu()

        self.build_tabs()

        self.build_status_bar()

    def build_top_bar(self):

        top = tk.Frame(self.root)

        top.pack(
            fill="x",
            padx=10,
            pady=6
        )

        tk.Label(
            top,
            text="Trade Data Workbench",
            font=("Arial", 17, "bold"),
        ).pack(side="left")

    def build_left_menu(self):

        left = tk.Frame(
            self.root,
            width=260
        )

        left.pack(
            side="left",
            fill="y",
            padx=10,
            pady=10
        )

        buttons = [

            (
                "0. Load Folder",
                self.load_folder
            ),

            (
                "1. Observe Data Files",
                self.observe_files
            ),

            (
                "2. Refresh Audit Log",
                self.refresh_audit
            ),
        ]

        for text, command in buttons:

            tk.Button(
                left,
                text=text,
                command=command,
                width=30,
                height=2,
                anchor="w",
            ).pack(
                fill="x",
                pady=4
            )

    def build_tabs(self):

        main = tk.Frame(self.root)

        main.pack(
            side="right",
            fill="both",
            expand=True,
            padx=10,
            pady=10
        )

        self.tabs = ttk.Notebook(main)

        self.tabs.pack(
            fill="both",
            expand=True
        )

        self.files_tab = ttk.Frame(self.tabs)

        self.profile_tab = ttk.Frame(self.tabs)

        self.audit_tab = ttk.Frame(self.tabs)

        self.tabs.add(
            self.files_tab,
            text="Files"
        )

        self.tabs.add(
            self.profile_tab,
            text="Observation"
        )

        self.tabs.add(
            self.audit_tab,
            text="Audit Log"
        )

        self.files_tree = ttk.Treeview(
            self.files_tab
        )

        self.files_tree.pack(
            fill="both",
            expand=True
        )

        self.profile_tree = ttk.Treeview(
            self.profile_tab
        )

        self.profile_tree.pack(
            fill="both",
            expand=True
        )

        self.audit_text = tk.Text(
            self.audit_tab,
            wrap="none"
        )

        self.audit_text.pack(
            fill="both",
            expand=True
        )

    def build_status_bar(self):

        self.status = tk.Label(
            self.root,
            text=f"Folder: {self.data_folder}",
            anchor="w",
        )

        self.status.pack(
            fill="x",
            side="bottom"
        )

    def load_folder(self):

        folder = filedialog.askdirectory(
            initialdir=self.data_folder
        )

        if not folder:
            return

        self.data_folder = folder

        self.status.config(
            text=f"Folder: {self.data_folder}"
        )

        log_action(
            "load_folder",
            f"Selected folder: {self.data_folder}"
        )

        messagebox.showinfo(
            "Folder Loaded",
            str(self.data_folder)
        )

    def observe_files(self):

        try:

            self.csv_files = list_csv_files(
                self.data_folder
            )

            self.show_file_list()

            self.profiles = profile_many_files(
                self.csv_files
            )

            self.show_profiles()

            log_action(
                "observe",
                f"Observed "
                f"{len(self.csv_files)} CSV files"
            )

            messagebox.showinfo(
                "Observation Complete",
                f"Found "
                f"{len(self.csv_files)} CSV files."
            )

        except Exception as e:

            log_action(
                "error",
                str(e)
            )

            messagebox.showerror(
                "Observation Error",
                str(e)
            )

    def show_file_list(self):

        self.files_tree.delete(
            *self.files_tree.get_children()
        )

        self.files_tree["columns"] = (
            "file",
            "size_mb",
            "path"
        )

        self.files_tree["show"] = "headings"

        for col in (
            "file",
            "size_mb",
            "path"
        ):

            self.files_tree.heading(
                col,
                text=col
            )

            self.files_tree.column(
                col,
                width=200
            )

        for file in self.csv_files:

            self.files_tree.insert(
                "",
                "end",
                values=(
                    file.name,
                    round(
                        file.stat().st_size / 1_000_000,
                        2
                    ),
                    str(file),
                ),
            )

    def show_profiles(self):

        self.profile_tree.delete(
            *self.profile_tree.get_children()
        )

        columns = (
            "file",
            "rows",
            "columns",
            "size_mb",
            "sample_null_pct",
            "empty_columns",
        )

        self.profile_tree["columns"] = columns

        self.profile_tree["show"] = "headings"

        for col in columns:

            self.profile_tree.heading(
                col,
                text=col
            )

            self.profile_tree.column(
                col,
                width=180
            )

        for profile in self.profiles:

            self.profile_tree.insert(
                "",
                "end",
                values=(
                    profile.get("file_name"),
                    profile.get("rows"),
                    profile.get("columns"),
                    profile.get("size_mb"),
                    profile.get("sample_null_pct"),
                    ", ".join(
                        profile.get(
                            "empty_columns",
                            []
                        )
                    ),
                ),
            )

    def refresh_audit(self):

        self.audit_text.delete(
            "1.0",
            tk.END
        )

        self.audit_text.insert(
            tk.END,
            read_audit_log()
        )

        log_action(
            "audit",
            "Audit log refreshed"
        )


