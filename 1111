from datetime import datetime
from pathlib import Path
import shutil
import polars as pl

from config import (
    DATASETS_FOLDER,
    BACKUPS_FOLDER,
    VERSIONS_FOLDER,
)

from core.audit import log_action


def make_dataset_id(prefix="dataset"):

    timestamp = datetime.now().strftime(
        "%Y%m%d_%H%M%S"
    )

    return f"{prefix}_{timestamp}"


def create_dataset_from_csvs(
    csv_files,
    selected_columns=None,
    exclude_empty_columns=True,
    dataset_name=None,
):

    dataset_id = dataset_name or make_dataset_id()

    scans = []

    for file in csv_files:

        scan = pl.scan_csv(
            file,
            infer_schema_length=1000
        )

        if selected_columns:

            available = scan.collect_schema().names()

            columns_to_use = [
                col for col in selected_columns
                if col in available
            ]

            scan = scan.select(columns_to_use)

        scans.append(scan)

    combined = pl.concat(
        scans,
        how="diagonal_relaxed"
    )

    df = combined.collect()

    if exclude_empty_columns:

        non_empty_columns = [
            col for col in df.columns
            if df[col].null_count() < df.height
        ]

        df = df.select(non_empty_columns)

    output_path = (
        DATASETS_FOLDER /
        f"{dataset_id}.parquet"
    )

    version_path = (
        VERSIONS_FOLDER /
        f"{dataset_id}_v001.parquet"
    )

    backup_path = (
        BACKUPS_FOLDER /
        f"{dataset_id}_backup.parquet"
    )

    df.write_parquet(output_path)

    df.write_parquet(version_path)

    shutil.copy2(
        output_path,
        backup_path
    )

    log_action(
        "create_dataset",
        f"Created {dataset_id} "
        f"with {df.height} rows "
        f"and {len(df.columns)} columns"
    )

    return {
        "dataset_id": dataset_id,
        "output_path": output_path,
        "version_path": version_path,
        "backup_path": backup_path,
        "rows": df.height,
        "columns": len(df.columns),
    }


def load_dataset(path: Path):

    return pl.read_parquet(path)


def save_dataset_version(
    df: pl.DataFrame,
    dataset_id: str
):

    timestamp = datetime.now().strftime(
        "%Y%m%d_%H%M%S"
    )

    version_path = (
        VERSIONS_FOLDER /
        f"{dataset_id}_{timestamp}.parquet"
    )

    df.write_parquet(version_path)

    log_action(
        "save_version",
        f"Saved version: {version_path.name}"
    )

    return version_path


def export_dataset(
    df: pl.DataFrame,
    output_path: Path
):

    if output_path.suffix.lower() == ".csv":

        df.write_csv(output_path)

    elif output_path.suffix.lower() == ".xlsx":

        df.to_pandas().to_excel(
            output_path,
            index=False
        )

    elif output_path.suffix.lower() == ".parquet":

        df.write_parquet(output_path)

    else:

        raise ValueError(
            "Supported exports: "
            ".csv, .xlsx, .parquet"
        )

    log_action(
        "export",
        f"Exported dataset to {output_path}"
    )


