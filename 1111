def get_surveillance_groups():
    """
    Return the full surveillance grouping dictionary.
    """
    return SURVEILLANCE_GROUPS


def get_group_names():
    """
    Return all group names.
    """
    return list(SURVEILLANCE_GROUPS.keys())


def get_group_details(group_name: str):
    """
    Return metadata for one group.
    """
    return SURVEILLANCE_GROUPS.get(group_name)


def get_patterns_for_group(group_name: str):
    """
    Return all patterns for a selected group.
    """
    group = SURVEILLANCE_GROUPS.get(group_name)

    if not group:
        return []

    return group.get("patterns", [])


def get_all_patterns():
    """
    Return all patterns as a flat list with group metadata.
    """
    all_patterns = []

    for group_name, group_data in SURVEILLANCE_GROUPS.items():
        for pattern in group_data.get("patterns", []):
            all_patterns.append({
                "group": group_name,
                "pattern": pattern,
                "memory_shortcut": group_data.get("memory_shortcut"),
                "core_intent": group_data.get("core_intent"),
                "mental_model": group_data.get("mental_model"),
            })

    return all_patterns


def search_patterns(search_text: str):
    """
    Search groups and patterns by text.
    """
    search_text = search_text.lower().strip()

    if not search_text:
        return get_all_patterns()

    results = []

    for item in get_all_patterns():
        searchable_text = (
            item["group"] + " " +
            item["pattern"] + " " +
            str(item.get("memory_shortcut", "")) + " " +
            str(item.get("core_intent", "")) + " " +
            str(item.get("mental_model", ""))
        ).lower()

        if search_text in searchable_text:
            results.append(item)

    return results


def count_patterns():
    """
    Return total number of pattern entries.
    Note: Some patterns appear in more than one group,
    such as Spoofing and Quote Stuffing.
    """
    return len(get_all_patterns())


def count_unique_patterns():
    """
    Return count of unique pattern names across all groups.
    """
    unique_patterns = set()

    for item in get_all_patterns():
        unique_patterns.add(item["pattern"])

    return len(unique_patterns)


