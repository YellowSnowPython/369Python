
Option Explicit

Sub FilterOrdersToTemplate()

    Dim wsT As Worksheet, wsO As Worksheet
    Dim src As Variant, outArr() As Variant
    Dim lastRow As Long, lastCol As Long
    Dim r As Long, c As Long, outRow As Long
    Dim headers As Object, filters As Object
    Dim keepRow As Boolean
    Dim key As Variant
    
    Set wsT = ThisWorkbook.Worksheets("Template")
    Set wsO = ThisWorkbook.Worksheets("Order")
    
    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.Calculation = xlCalculationManual
    
    lastRow = wsO.Cells(wsO.Rows.Count, 1).End(xlUp).Row
    lastCol = wsO.Cells(1, wsO.Columns.Count).End(xlToLeft).Column
    
    If lastRow < 2 Then GoTo CleanExit
    
    src = wsO.Range(wsO.Cells(1, 1), wsO.Cells(lastRow, lastCol)).Value
    
    Set headers = CreateObject("Scripting.Dictionary")
    For c = 1 To lastCol
        headers(CStr(src(1, c))) = c
    Next c
    
    Set filters = CreateObject("Scripting.Dictionary")
    
    'Template cell -> Order tab column header
    AddFilter filters, "Order Type", wsT.Range("B2").Value
    AddFilter filters, "Order Status", wsT.Range("B3").Value
    AddFilter filters, "Price", wsT.Range("B4").Value
    AddFilter filters, "Quote Type", wsT.Range("B5").Value
    AddFilter filters, "Side", wsT.Range("B6").Value
    AddFilter filters, "Execution Terms", wsT.Range("B7").Value
    
    ReDim outArr(1 To lastRow, 1 To lastCol)
    
    'Copy headers
    For c = 1 To lastCol
        outArr(1, c) = src(1, c)
    Next c
    
    outRow = 1
    
    For r = 2 To UBound(src, 1)
        keepRow = True
        
        For Each key In filters.Keys
            If headers.Exists(CStr(key)) Then
                If Not MatchFilter(src(r, headers(key)), filters(key)) Then
                    keepRow = False
                    Exit For
                End If
            End If
        Next key
        
        If keepRow Then
            outRow = outRow + 1
            For c = 1 To lastCol
                outArr(outRow, c) = src(r, c)
            Next c
        End If
    Next r
    
    wsT.Range("A10").Resize(wsT.Rows.Count - 9, lastCol).ClearContents
    
    If outRow >= 1 Then
        wsT.Range("A10").Resize(outRow, lastCol).Value = outArr
    End If

CleanExit:
    Application.Calculation = xlCalculationAutomatic
    Application.EnableEvents = True
    Application.ScreenUpdating = True

End Sub

Private Sub AddFilter(ByRef filters As Object, ByVal fieldName As String, ByVal criteria As String)

    criteria = Trim(CStr(criteria))
    
    If criteria <> "" And LCase(criteria) <> "all" Then
        filters(fieldName) = SplitCriteria(criteria)
    End If

End Sub

Private Function SplitCriteria(ByVal criteria As String) As Object

    Dim dict As Object
    Dim arr As Variant
    Dim i As Long
    Dim item As String
    
    Set dict = CreateObject("Scripting.Dictionary")
    dict.CompareMode = vbTextCompare
    
    arr = Split(criteria, ",")
    
    For i = LBound(arr) To UBound(arr)
        item = Trim(CStr(arr(i)))
        If item <> "" Then dict(item) = True
    Next i
    
    Set SplitCriteria = dict

End Function

Private Function MatchFilter(ByVal cellValue As Variant, ByVal allowedValues As Object) As Boolean

    Dim v As String
    v = Trim(CStr(cellValue))
    
    MatchFilter = allowedValues.Exists(v)

End Function
