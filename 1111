"""
surveillance/registry.py

Central registry for surveillance groups, patterns, metadata,
and future detector mappings.
"""

from surveillance.groups import SURVEILLANCE_GROUPS


def get_all_groups():
    """
    Return the full surveillance group dictionary.
    """
    return SURVEILLANCE_GROUPS


def get_group_names():
    """
    Return all surveillance group names.
    """
    return list(SURVEILLANCE_GROUPS.keys())


def get_group(group_name: str):
    """
    Return one group by name.
    """
    return SURVEILLANCE_GROUPS.get(group_name)


def get_patterns_by_group(group_name: str):
    """
    Return pattern names for a selected group.
    """
    group = get_group(group_name)

    if not group:
        return []

    return group.get("patterns", [])


def get_all_patterns():
    """
    Return all pattern records as a flat list.
    """
    patterns = []

    for group_name, group_data in SURVEILLANCE_GROUPS.items():
        for pattern_name in group_data.get("patterns", []):
            patterns.append({
                "group": group_name,
                "pattern": pattern_name,
                "memory_shortcut": group_data.get("memory_shortcut"),
                "core_intent": group_data.get("core_intent"),
                "mental_model": group_data.get("mental_model"),
                "observable_patterns": group_data.get("observable_patterns", []),
                "surveillance_questions": group_data.get("surveillance_questions", []),
                "recommended_charts": group_data.get("recommended_charts", []),
            })

    return patterns


def get_unique_patterns():
    """
    Return unique pattern names across all groups.
    Some patterns may appear in more than one group.
    """
    return sorted({
        item["pattern"]
        for item in get_all_patterns()
    })


def find_pattern(pattern_name: str):
    """
    Find all registry entries for a pattern name.
    Useful when a pattern appears in multiple groups.
    """
    matches = []

    for item in get_all_patterns():
        if item["pattern"].lower() == pattern_name.lower():
            matches.append(item)

    return matches


def search_patterns(search_text: str):
    """
    Search group names, pattern names, intent, and mental model.
    """
    search_text = search_text.lower().strip()

    if not search_text:
        return get_all_patterns()

    results = []

    for item in get_all_patterns():
        searchable = " ".join([
            str(item.get("group", "")),
            str(item.get("pattern", "")),
            str(item.get("memory_shortcut", "")),
            str(item.get("core_intent", "")),
            str(item.get("mental_model", "")),
            " ".join(item.get("observable_patterns", [])),
            " ".join(item.get("surveillance_questions", [])),
            " ".join(item.get("recommended_charts", [])),
        ]).lower()

        if search_text in searchable:
            results.append(item)

    return results


def count_pattern_entries():
    """
    Count all pattern entries, including duplicates across groups.
    """
    return len(get_all_patterns())


def count_unique_patterns():
    """
    Count unique pattern names.
    """
    return len(get_unique_patterns())


