def get_detector(pattern_name: str):
    """
    Return detector assigned to a pattern.
    Currently returns None until detector modules are built.
    """
    return DETECTOR_REGISTRY.get(pattern_name)


def has_detector(pattern_name: str):
    """
    Return True if a detector has been registered.
    """
    return DETOR_REGISTRY.get(pattern_name) is not None
