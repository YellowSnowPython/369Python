from pathlib import Path
import polars as pl


def list_csv_files(folder: Path):
    return sorted(folder.glob("*.csv"))


def profile_csv_file(file_path: Path):

    scan = pl.scan_csv(
        file_path,
        infer_schema_length=1000
    )

    row_count = scan.select(pl.len()).collect().item()

    sample = scan.limit(1000).collect()

    total_cells = sample.height * len(sample.columns)

    null_cells = sample.null_count().row(0)

    null_total = sum(null_cells)

    empty_columns = [
        col for col in sample.columns
        if sample[col].null_count() == sample.height
    ]

    return {
        "file_name": file_path.name,
        "file_path": str(file_path),
        "size_mb": round(file_path.stat().st_size / 1_000_000, 2),
        "rows": row_count,
        "columns": len(sample.columns),
        "column_names": sample.columns,
        "empty_columns": empty_columns,
        "sample_null_pct": round(
            (null_total / total_cells) * 100,
            2
        ) if total_cells else 0,
    }


def profile_many_files(files):

    profiles = []

    for file in files:

        try:
            profiles.append(
                profile_csv_file(file)
            )

        except Exception as e:

            profiles.append({
                "file_name": file.name,
                "file_path": str(file),
                "size_mb": round(
                    file.stat().st_size / 1_000_000,
                    2
                ),
                "rows": "ERROR",
                "columns": "ERROR",
                "column_names": [],
                "empty_columns": [],
                "sample_null_pct": "ERROR",
                "error": str(e),
            })

    return profiles


